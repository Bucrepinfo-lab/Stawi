# Monorepo peer-dep policy.
#
# apps/web uses react/react-dom ^18.3 (Next 15); apps/mobile is pinned to
# react 18.2.0 (Expo 51 / RN 0.74 requirement). Strict peer resolution makes
# npm hoist react-dom@19 to satisfy @clerk/clerk-expo "^18 || ^19", pairing
# React 18 with React-DOM 19 and breaking the Next.js build (useContext null
# at prerender). Legacy mode keeps each workspace on its declared versions.
legacy-peer-deps=true
