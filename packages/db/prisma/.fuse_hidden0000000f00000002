// Stawi data model — Pillars 1–3.
// Postgres on DigitalOcean Managed DB. Auth identities come from Clerk
// (clerkUserId / clerkOrgId); this schema holds domain data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Groups & members ───────────────────────────

enum GroupType {
  CHAMA // informal
  SELF_HELP_GROUP // registered SHG
  SACCO // cooperative
  BUSINESS // solo / company
}

enum MemberRole {
  CHAIRMAN
  SECRETARY
  TREASURER
  SIGNATORY
  MEMBER
}

enum SalesTier {
  CONSTITUENCY
  COUNTY
  NATIONAL
  CONTINENTAL
  GLOBAL
  SUPER_ADMIN
}

model Group {
  id          String     @id @default(cuid())
  clerkOrgId  String     @unique
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  name        String
  type        GroupType  @default(CHAMA)
  countryCode String     @default("KE")
  flagEmoji   String     @default("🇰🇪")
  // Formalization wizard progress (0–5 for Kenya SHG).
  formalizationStep Int  @default(0)

  members       Membership[]
  contributions Contribution[]
  cycles        Cycle[]
  subscription  Subscription?
  business      Business?
  salesRepId    String?
  salesRep      SalesAgent? @relation(fields: [salesRepId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id          String     @id @default(cuid())
  clerkUserId String
  group       Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  fullName    String
  phone       String?
  photoUrl    String?
  role        MemberRole @default(MEMBER)
  rotationOrder Int      @default(0)

  contributions Contribution[]

  joinedAt DateTime @default(now())

  @@unique([groupId, clerkUserId])
  @@index([groupId])
}

// ───────────────────────── Table banking (Pillar 1) ─────────────────────

model Cycle {
  id          String   @id @default(cuid())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  index       Int // 1-based cycle number
  recipientMembershipId String?
  payoutCents Int      @default(0)
  closedAt    DateTime?
  createdAt   DateTime @default(now())

  @@unique([groupId, index])
}

enum PaymentChannel {
  MPESA_STK
  MPESA_C2B
  BANK
  CASH
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model Contribution {
  id           String         @id @default(cuid())
  group        Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
  member       Membership     @relation(fields: [membershipId], references: [id])
  membershipId String
  amountCents  Int
  channel      PaymentChannel @default(MPESA_STK)
  status       PaymentStatus  @default(PENDING)
  // M-Pesa Daraja references.
  mpesaRef     String?
  checkoutRequestId String?
  recordedByClerkUserId String? // treasurer who filed it
  receiptUrl   String?
  createdAt    DateTime       @default(now())

  @@index([groupId, status])
  @@index([membershipId])
}

// ───────────────────────── Subscriptions / billing ─────────────────────

enum SubStatus {
  TRIAL // first month free
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id           String    @id @default(cuid())
  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String    @unique
  status       SubStatus @default(TRIAL)
  unitPriceCents Int     @default(1000) // 10 units
  currentPeriodEnd DateTime?
  createdAt    DateTime  @default(now())
}

// ───────────────────────── Business / accounting (Pillar 3) ─────────────

model Business {
  id            String   @id @default(cuid())
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String   @unique
  name          String
  vatRegistered Boolean  @default(false)
  tourismSector Boolean  @default(false)
  kraPin        String?

  ventures   SavedVenture[]
  stockItems StockItem[]
  entries    LedgerEntry[]
  createdAt  DateTime @default(now())
}

// Pillar 2 — saved/booked business ideas (shortlist of 3).
model SavedVenture {
  id          String   @id @default(cuid())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  title       String
  industry    String
  startupCents Int
  marginPct   Int
  risk        String
  createdAt   DateTime @default(now())
}

model StockItem {
  id          String   @id @default(cuid())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  name        String
  quantity    Int      @default(0)
  reorderLevel Int     @default(5)
  /** Units sold in the rolling analysis window (e.g. last 7 days). */
  soldInWindow Int     @default(0)
  supplierName String?
  supplierPhone String?
  createdAt   DateTime @default(now())

  @@index([businessId])
}

enum EntryType {
  SALE
  PURCHASE
  EXPENSE
}

model LedgerEntry {
  id          String    @id @default(cuid())
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  type        EntryType
  description String
  amountCents Int
  occurredAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([businessId, occurredAt])
}

// ───────────────────────── Sales hierarchy / admin ─────────────────────

model SalesAgent {
  id          String     @id @default(cuid())
  clerkUserId String     @unique
  fullName    String
  tier        SalesTier
  region      String? // e.g. "Westlands", "Nairobi", "Kenya"
  // Self-referencing supervision chain.
  supervisorId String?
  supervisor   SalesAgent?  @relation("Supervision", fields: [supervisorId], references: [id])
  reports   