// Stawi data model — global multi-tenant SaaS. Pillars 1–3 + tenancy.
// Postgres on DigitalOcean Managed DB. Auth identities come from Clerk
// (clerkUserId / clerkOrgId); this schema holds domain data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Multi-tenant SaaS ─────────────────────────

enum PlanTier {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

/// Top-level billing & isolation boundary. Owns many Groups/Businesses.
model Tenant {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  countryCode String         @default("KE")
  planTier    PlanTier       @default(FREE)
  groups      Group[]
  members     TenantMember[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model TenantMember {
  id          String     @id @default(cuid())
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  clerkUserId String
  role        TenantRole @default(MEMBER)
  createdAt   DateTime   @default(now())

  @@unique([tenantId, clerkUserId])
  @@index([tenantId])
}

// ─────────────────────────── Groups & members ───────────────────────────

enum GroupType {
  CHAMA
  SELF_HELP_GROUP
  SACCO
  BUSINESS
}

enum MemberRole {
  CHAIRMAN
  SECRETARY
  TREASURER
  SIGNATORY
  MEMBER
}

enum SalesTier {
  CONSTITUENCY
  COUNTY
  NATIONAL
  CONTINENTAL
  GLOBAL
  SUPER_ADMIN
}

model Group {
  id          String     @id @default(cuid())
  clerkOrgId  String     @unique
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  name        String
  type        GroupType  @default(CHAMA)
  countryCode String     @default("KE")
  flagEmoji   String     @default("🇰🇪")
  formalizationStep Int  @default(0)

  members       Membership[]
  contributions Contribution[]
  cycles        Cycle[]
  subscription  Subscription?
  business      Business?
  salesRepId    String?
  salesRep      SalesAgent? @relation(fields: [salesRepId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Membership {
  id          String     @id @default(cuid())
  clerkUserId String
  group       Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  fullName    String
  phone       String?
  photoUrl    String?
  role        MemberRole @default(MEMBER)
  rotationOrder Int      @default(0)

  contributions Contribution[]

  joinedAt DateTime @default(now())

  @@unique([groupId, clerkUserId])
  @@index([groupId])
}

// ───────────────────────── Table banking (Pillar 1) ─────────────────────

model Cycle {
  id          String   @id @default(cuid())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  index       Int
  recipientMembershipId String?
  payoutCents Int      @default(0)
  closedAt    DateTime?
  createdAt   DateTime @default(now())

  @@unique([groupId, index])
}

enum PaymentChannel {
  MPESA_STK
  MPESA_C2B
  BANK
  CASH
  CARD
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model Contribution {
  id           String         @id @default(cuid())
  group        Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String
  member       Membership     @relation(fields: [membershipId], references: [id])
  membershipId String
  amountCents  Int
  channel      PaymentChannel @default(MPESA_STK)
  status       PaymentStatus  @default(PENDING)
  mpesaRef     String?
  checkoutRequestId String?
  recordedByClerkUserId String?
  receiptUrl   String?
  createdAt    DateTime       @default(now())

  @@index([groupId, status])
  @@index([membershipId])
}

// ───────────────────────── Subscriptions / billing ─────────────────────

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id           String    @id @default(cuid())
  planTier     PlanTier  @default(FREE)
  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId      String    @unique
  status       SubStatus @default(TRIAL)
  unitPriceCents Int     @default(1000)
  currency     String    @default("USD")
  currentPeriodEnd DateTime?
  termsAcceptedAt DateTime?
  createdAt    DateTime  @default(now())
}

// ───────────────────────── Business / accounting (Pillar 3) ─────────────

model Business {
  id            String   @id @default(cuid())
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String   @unique
  name          String
  vatRegistered Boolean  @default(false)
  tourismSector Boolean  @default(false)
  taxId         String?

  ventures   SavedVenture[]
  stockItems StockItem[]
  entries    LedgerEntry[]
  createdAt  DateTime @default(now())
}

model SavedVenture {
  id          String   @id @default(cuid())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  title       String
  industry    String
  startupCents Int
  marginPct   Int
  risk        String
  createdAt   DateTime @default(now())
}

model StockItem {
  id          String   @id @default(cuid())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  name        String
  quantity    Int      @default(0)
  reorderLevel Int     @default(5)
  soldInWindow Int     @default(0)
  supplierName String?
  supplierPhone String?
  createdAt   DateTime @default(now())

  @@index([businessId])
}

enum EntryType {
  SALE
  PURCHASE
  EXPENSE
}

model LedgerEntry {
  id          String    @id @default(cuid())
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId  String
  type        EntryType
  description String
  amountCents Int
  occurredAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([businessId, occurredAt])
}

// ───────────────────────── Sales hierarchy / admin ─────────────────────

model SalesAgent {
  id          String       @id @default(cuid())
  clerkUserId String       @unique
  fullName    String
  tier        SalesTier
  region      String?
  supervisorId String?
  supervisor   SalesAgent?  @relation("Supervision", fields: [supervisorId], references: [id])
  reports      SalesAgent[] @relation("Supervision")
  groups       Group[]
  createdAt    DateTime     @default(now())
}

// ───────────────────────── Trust & safety ─────────────────────

enum ModerationAction {
  ALLOWED
  FLAGGED
  BLOCKED
}

/// Audit log of moderation decisions on user-generated content.
model ModerationLog {
  id          String           @id @default(cuid())
  clerkUserId String?
  context     String           // e.g. "ledger_entry", "message", "venture"
  action      ModerationAction
  categories  String           // comma-separated
  createdAt   DateTime         @default(now())

  @@index([clerkUserId])
}
